[Unit]
Description=NEURO — Online platform for parents
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/neuro
ExecStart=/usr/bin/npx next start --hostname 0.0.0.0 --port 3000
Restart=on-failure
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
